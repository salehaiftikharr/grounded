# Embeddings — OpenAI text-embedding-3-small (used to index the corpus and the query)
OPENAI_API_KEY=

# Generation — Anthropic Claude by default. Set LLM_PROVIDER=openai to answer with GPT instead.
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic

# Optional model overrides
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_MODEL=gpt-4.1
# EMBEDDING_MODEL=text-embedding-3-small
