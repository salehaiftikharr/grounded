# ElevenLabs voice layer for Grounded.
# Copy these into the project's real .env.local (do NOT commit that file).
# Also add both to the Vercel project (Settings -> Environment Variables)
# so the deployed app has them.

# Required. Get this from elevenlabs.io -> your profile -> API key.
ELEVENLABS_API_KEY=

# Optional. A voice ID from your ElevenLabs Voices page. If unset, the app
# falls back to the default public "Rachel" voice.
ELEVENLABS_VOICE_ID=
